{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:inspect": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "serve-storybook": "serve storybook-static",
    "i18n": "sync-i18n -f i18n/locales/**/**.json --primary pt --space 2 -newkeysempty",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "test": "node sync-i18n.ts",
    "sanity:start": "dotenv -e .env sanity dev",
    "sanity:build": "sanity build",
    "sanity:deploy": "sanity deploy",
    "sanity:generate-types": "sanity schema extract --enforce-required-fields && sanity typegen generate"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@portabletext/react": "^3.2.1",
    "@sanity/client": "^6.27.2",
    "@sanity/vision": "^3.74.1",
    "@sentry/nextjs": "^8.54.0",
    "@tanstack/react-table": "^8.20.6",
    "@uiw/react-markdown-preview": "^5.1.3",
    "accept-language": "^3.0.20",
    "autoprefixer": "^10.4.20",
    "classname-variants": "^1.5.0",
    "classnames": "^2.5.1",
    "country-flag-icons": "^1.5.16",
    "eslint": "^9.20.0",
    "eslint-config-next": "~15.1.6",
    "groq": "^3.74.1",
    "i18next": "~24.2.2",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-resources-to-backend": "^1.2.1",
    "import-in-the-middle": "^1.13.0",
    "lodash.groupby": "^4.6.0",
    "next": "~15.1.6",
    "next-i18n-router": "^5.5.1",
    "next-sanity": "^9.8.54",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prop-types": "^15.8.1",
    "react": "~19.0.0",
    "react-datepicker": "7.5.0",
    "react-dom": "~19.0.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.0",
    "react-icons": "^5.4.0",
    "react-paginate": "^8.3.0",
    "require-in-the-middle": "^7.5.1",
    "sanity": "^3.74.1",
    "sanity-plugin-cloudinary": "^1.1.5",
    "sanity-plugin-internationalized-array": "^3.1.1",
    "styled-components": "^6.1",
    "swiper": "^11.2.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "~8.4.7",
    "@storybook/addon-interactions": "~8.4.7",
    "@storybook/addon-links": "~8.4.7",
    "@storybook/addon-onboarding": "~8.4.7",
    "@storybook/blocks": "~8.4.7",
    "@storybook/nextjs": "~8.4.7",
    "@storybook/react": "~8.4.7",
    "@storybook/test": "~8.4.7",
    "@types/country-flag-icons": "^1.2.2",
    "@types/lodash.groupby": "^4.6.9",
    "@types/node": "^22.13.1",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/react-paginate": "^7.1.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-storybook": "^0.11.2",
    "storybook": "~8.4.7"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.0",
      "@types/react-dom": "19.0.0"
    }
